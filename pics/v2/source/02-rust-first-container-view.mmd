    ADP["TS Adapter Service"]
  end

  subgraph Z1["Trusted App Zone"]
    CORE["Rust Core Service"]
    POL["Policy/Approvals"]
    AUD["Audit Pipeline"]
    SES["Session Store Access"]
  end

  subgraph Z2["Data Zone"]
    DB[("Postgres HA")]
    KMS["Key Vault"]
  end

  subgraph Z3["External APIs"]
    MG["Microsoft Graph"]
    LLM["Azure OpenAI"]
  end

  TEAMS --> ADP
  ADP -->|"mTLS gRPC"| CORE
  CORE --> POL
  CORE --> AUD
